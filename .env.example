# Optional remote model provider. Leave blank for local agent mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AGENT_PROVIDER=local

# Local browser AI access is opt-in and development-only.
# The request Host and Origin must exactly match a loopback URL.
EDITOR_LOCAL_AI_ENABLED=true

# Shared/public deployments require all three values below and HTTPS.
# The current browser UI does not persist or send the operator bearer token.
EDITOR_REMOTE_AI_ENABLED=false
EDITOR_ALLOWED_ORIGINS=https://editor.example.com
EDITOR_API_TOKEN=
