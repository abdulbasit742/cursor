# Optional remote model provider. Leave blank for local agent mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AGENT_PROVIDER=local

# AI API routes are loopback-only by default.
# Public deployments require all three values below and HTTPS.
EDITOR_REMOTE_AI_ENABLED=false
EDITOR_ALLOWED_ORIGINS=https://editor.example.com
EDITOR_API_TOKEN=
